{
  "uid": "parent-dashboard",
  "title": "Parent Dashboard — Кирилл (T1D-friendly)",
  "tags": ["ai-tutor", "sprint-39", "parent", "t1d-safety"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "1m",
  "time": { "from": "now-7d", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "🟢 Streak (текущая / лучшая)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 3 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "parent_streak_current_streak_days",
          "legendFormat": "current",
          "refId": "A"
        },
        {
          "expr": "parent_streak_longest_streak_days",
          "legendFormat": "longest",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "📊 Активность (attempts/день, last 7d)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "sum by (day) (increase(parent_attempts_total[1d]))",
          "legendFormat": "{{day}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "🎯 Mastery по предметам (avg)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.4 },
              { "color": "green", "value": 0.7 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "targets": [
        {
          "expr": "parent_subject_mastery_avg",
          "legendFormat": "{{subject}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "⚠️ Слабые темы (mastery < 0.6)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "parent_weak_topics",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "🛑 T1D Session Pauses (по reason, last 7d)",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum by (reason) (increase(parent_session_pauses_total[7d]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "⏱ Средняя длина сессии (min)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 40 }
            ]
          },
          "unit": "m"
        }
      },
      "targets": [
        {
          "expr": "parent_session_avg_duration_minutes",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "📈 Попытки за неделю vs в среднем",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "sum(increase(parent_attempts_total[7d]))",
          "legendFormat": "this week",
          "refId": "A"
        },
        {
          "expr": "sum(increase(parent_attempts_total[7d] offset 7d))",
          "legendFormat": "prev week",
          "refId": "B"
        }
      ]
    }
  ]
}
