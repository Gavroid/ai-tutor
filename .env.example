# Замените все change_me на свои значения перед запуском.
# Этот файл коммитится в репозиторий (в отличие от .env).

APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=change_me_at_least_32_chars_long_xxxxx

# PostgreSQL
POSTGRES_USER=tutor
POSTGRES_PASSWORD=change_me
POSTGRES_DB=tutor
DATABASE_URL=postgresql+psycopg2://tutor:change_me@db:5432/tutor

# CORS — внешние origin'ы через запятую
CORS_ORIGINS=http://localhost,http://localhost:3000

# Загрузки
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=20

# AI Gateway (Этап 5)
AI_BASE_URL=https://api.openrouter.ai/api/v1
AI_API_KEY=change_me
AI_MODEL=anthropic/claude-3.5-haiku
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2
AI_MAX_INPUT_CHARS=8000

# JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=1440
JWT_REFRESH_TTL_DAYS=30

# Rate limit
RATE_LIMIT_AI_PER_MINUTE=30

# Frontend (NEXT_PUBLIC_API_URL пробрасывается в браузер при сборке)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Pilot Core: voice отключён по умолчанию (raw API нестабилен, UI скрыт).
# Установите =1 чтобы включить кнопку микрофона в /topics/[id] для тестов.
NEXT_PUBLIC_VOICE_ENABLED=0

# Pilot Core: обязательный токен для seed_users CLI (≥16 символов).
# Сгенерируйте: openssl rand -hex 16
PILOT_SEED_TOKEN=change_me_to_a_random_16char_value
